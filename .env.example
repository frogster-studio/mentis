# Copy to .env.local and fill in. Every variable is server-side only — none are
# exposed to the browser (no NEXT_PUBLIC_ prefix).

# Supabase project URL (Project Settings → Data API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key (Project Settings → API keys → service_role).
# Full-access key: server-side only, never ship it to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of editor emails allowed to log in.
ALLOWED_EMAILS=alice@example.com,bob@example.com

# Single password shared by all editors.
SHARED_PASSWORD=

# Random secret used to sign the session cookie (introduced with the auth issue).
# Generate one with: openssl rand -base64 32
SESSION_SECRET=
